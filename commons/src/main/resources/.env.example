# LLM 提供商：dashscope | deepseek
LLM_PROVIDER=deepseek

# DashScope（LLM_PROVIDER=dashscope 时使用）
ALIBABA_DASHSCOPE_API_KEY=
DASHSCOPE_MODEL_NAME=qwen-plus

# DeepSeek（LLM_PROVIDER=deepseek 时使用）
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL_NAME=deepseek-v4-pro
DEEPSEEK_BASE_URL=https://api.deepseek.com
# A2A 子 Agent 建议关闭流式，避免 chunked 传输中断
DEEPSEEK_STREAM=false

# 百度地图 MCP
BAIDU_MAP_KEY=

# RAG（TripPlannerAgent，SimpleKnowledge + AGENTIC）
RAG_ENABLED=true
# DeepSeek 暂无 /v1/embeddings，Phase 1 使用 local 哈希向量
EMBEDDING_PROVIDER=local
EMBEDDING_DIMENSIONS=1024
RAG_RETRIEVE_LIMIT=5
RAG_SCORE_THRESHOLD=0.35
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50
